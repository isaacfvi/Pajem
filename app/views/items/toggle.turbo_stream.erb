<%= turbo_stream.replace dom_id(@item), partial: "items/item", locals: { item: @item, list: @list } %>
<%= turbo_stream.update dom_id(@list, :progress) do %>
  <%= render "lists/progress_bar", list: @list %>
<% end %>
<%= turbo_stream.update "#{dom_id(@list, :progress)}_panel" do %>
  <%= render "lists/progress_bar", list: @list %>
<% end %>
