<% content_for :title, "Entrar — Pajem" %>

<div class="auth-page">
  <div class="auth-card">
    <h1 class="auth-card__title">Entrar</h1>

    <%= render "shared/flash" %>

    <%= form_with url: login_path, class: "auth-form" do |f| %>
      <div class="form-group">
        <%= f.label :email, "E-mail", class: "form-label" %>
        <%= f.email_field :email,
              name: "email",
              class: "form-input",
              placeholder: "voce@exemplo.com",
              autocomplete: "email",
              autofocus: true %>
      </div>

      <div class="form-group">
        <%= f.label :password, "Senha", class: "form-label" %>
        <%= f.password_field :password,
              name: "password",
              class: "form-input",
              placeholder: "••••••••",
              autocomplete: "current-password" %>
      </div>

      <div class="form-actions">
        <%= f.submit "Entrar", class: "btn btn--primary" %>
      </div>
    <% end %>

    <div class="auth-card__footer">
      <p class="form-link">
        <%= link_to "Esqueci minha senha", forgot_password_path %>
      </p>
      <p class="form-link">
        Não tem uma conta? <%= link_to "Cadastre-se", signup_path %>
      </p>
    </div>
  </div>
</div>
