<%= turbo_frame_tag "items_filter_frame_#{@list.id}" do %>
  <div class="items-filter">
    <%= form_with url: list_items_path(@list), method: :get, class: "items-filter__form" do |f| %>
      <%= f.text_field :q, value: params[:q], placeholder: "Buscar itens…",
            class: "filter__search filter__search--sm",
            autocomplete: "off" %>
      <%= f.select :status,
            [ [ "Todos", "" ], [ "Pendentes", "pending" ], [ "Concluídos", "done" ] ],
            { selected: params[:status], include_blank: false },
            { class: "filter__select filter__select--sm", onchange: "this.form.requestSubmit()" } %>
      <%= f.select :priority,
            [ [ "Prioridade", "" ], [ "Baixa", "low" ], [ "Média", "medium" ], [ "Alta", "high" ] ],
            { selected: params[:priority], include_blank: false },
            { class: "filter__select filter__select--sm", onchange: "this.form.requestSubmit()" } %>
      <%= f.select :due,
            [ [ "Prazo", "" ], [ "Vencidos", "overdue" ], [ "Hoje", "today" ], [ "Esta semana", "week" ] ],
            { selected: params[:due], include_blank: false },
            { class: "filter__select filter__select--sm", onchange: "this.form.requestSubmit()" } %>
      <%= f.submit "Buscar", class: "btn btn--ghost btn--sm" %>
      <% if params[:q].present? || params[:status].present? || params[:priority].present? || params[:due].present? %>
        <%= link_to "Limpar", list_items_path(@list), class: "btn btn--ghost btn--sm" %>
      <% end %>
    <% end %>
  </div>

  <div id="list_items_<%= @list.id %>" class="list-expanded__items">
    <% if @items.empty? %>
      <p class="list-expanded__empty">Nenhum item encontrado.</p>
    <% else %>
      <% @items.each do |item| %>
        <%= render "items/item", item: item, list: @list %>
      <% end %>
    <% end %>
  </div>
<% end %>
