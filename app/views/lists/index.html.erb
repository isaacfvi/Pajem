<% content_for :hide_content_header, "1" %>

<div class="lists-page" data-controller="list-expand">

  <%# Header do grid — visível enquanto nenhuma lista está aberta %>
  <div class="content-header" data-list-expand-target="gridHeader">
    <h1 class="content-header__title"><%= @active_context&.name || "Todas as listas" %></h1>
    <div class="content-header__actions">
      <%= link_to "+ Nova Lista", new_list_path, class: "btn btn--primary" %>
    </div>
  </div>

  <%# Grid de post-its %>
  <div class="postit-grid" data-list-expand-target="grid">
    <% @lists.each do |list| %>
      <%
        all_items    = list.items.reject(&:discarded?)
        pending      = all_items.reject(&:completed).count
        palette      = List::PALETTE.find { |p| p[:bg] == list.color }
        color_class  = palette ? "colored-card #{palette[:css]}" : ""
      %>
      <div class="postit <%= color_class %>"
           data-action="click->list-expand#expand"
           data-list-expand-list-id-param="<%= list.id %>">
        <div class="postit__header">
          <span class="postit__title"><%= list.title %></span>
          <div class="postit__actions" data-action="click->list-expand#noop:stop">
            <%= link_to edit_list_path(list), class: "postit__action-btn", title: "Editar lista" do %>&#9998;<% end %>
            <%= button_to list_path(list), method: :delete,
                  class: "postit__action-btn postit__action-btn--danger",
                  title: "Excluir lista",
                  form: { class: "postit__action-form" } do %>&#10005;<% end %>
          </div>
        </div>
        <div class="postit__meta">
          <%= pending == 1 ? "1 item pendente" : "#{pending} itens pendentes" %>
        </div>
        <div id="<%= dom_id(list, :progress) %>">
          <%= render "lists/progress_bar", list: list %>
        </div>
      </div>
    <% end %>

    <% if @lists.empty? %>
      <div class="postit postit--empty">
        <p>Nenhuma lista ainda.</p>
        <%= link_to "Criar primeira lista", new_list_path, class: "btn btn--primary postit__empty-cta" %>
      </div>
    <% end %>
  </div>

  <%# Painéis expandidos — pré-renderizados, ocultos via CSS %>
  <% @lists.each do |list| %>
    <%
      palette     = List::PALETTE.find { |p| p[:bg] == list.color }
      color_class = palette ? "colored-card #{palette[:css]}" : ""
      panel_items = list.items.to_a.reject(&:discarded?)
                        .sort_by { |i| [ i.completed ? 1 : 0, -(Item.priorities[i.priority] || -1), i.created_at.to_f ] }
    %>
    <div class="list-expanded hidden <%= color_class %>"
         data-list-expand-target="panel"
         data-list-id="<%= list.id %>">

      <div class="list-expanded__header">
        <div>
          <h2 class="list-expanded__title"><%= list.title %></h2>
          <% if list.description.present? || list.context %>
            <p class="list-expanded__subtitle">
              <%= list.description.presence || list.context&.name %>
            </p>
          <% end %>
        </div>
        <div class="list-expanded__header-actions">
          <%= link_to "Editar", edit_list_path(list), class: "btn btn--ghost" %>
          <button class="btn btn--ghost" data-action="click->list-expand#collapse">Fechar</button>
        </div>
      </div>

      <div id="<%= dom_id(list, :progress) %>_panel">
        <%= render "lists/progress_bar", list: list %>
      </div>

      <div id="list_items_<%= list.id %>" class="list-expanded__items">
        <% if panel_items.empty? %>
          <p class="list-expanded__empty">Nenhum item nesta lista.</p>
        <% end %>
        <% panel_items.each do |item| %>
          <%= render "items/item", item: item, list: list %>
        <% end %>
      </div>

      <div id="new_item_form_<%= list.id %>" class="list-expanded__new-form">
        <%= render "items/new_form", item: Item.new, list: list %>
      </div>

    </div>
  <% end %>

</div>
