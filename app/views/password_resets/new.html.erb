<% content_for :title, "Recuperar senha — Pajem" %>

<div class="auth-page">
  <div class="auth-card">
    <h1 class="auth-card__title">Recuperar senha</h1>
    <p class="auth-card__subtitle">Informe seu e-mail e enviaremos as instruções para redefinir sua senha.</p>

    <%= render "shared/flash" %>

    <%= form_with url: forgot_password_path do |f| %>
      <div class="form-group">
        <%= f.label :email, "E-mail", class: "form-label" %>
        <%= f.email_field :email,
              name: "email",
              class: "form-input",
              placeholder: "voce@exemplo.com",
              autocomplete: "email",
              autofocus: true %>
      </div>

      <div class="form-actions">
        <%= f.submit "Enviar instruções", class: "btn btn--primary" %>
      </div>
    <% end %>

    <div class="auth-card__footer">
      <p class="form-link"><%= link_to "← Voltar ao login", login_path %></p>
    </div>
  </div>
</div>
