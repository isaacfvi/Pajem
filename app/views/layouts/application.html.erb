<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Pajem" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Pajem">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Script inline antes do CSS para evitar flash de tema errado no reload %>
    <script>
      if (localStorage.getItem('theme') === 'dark') {
        document.documentElement.setAttribute('data-theme', 'dark');
      }
    </script>

    <%= stylesheet_link_tag "application",
                            "layout/topbar",
                            "layout/sidebar",
                            "layout/content",
                            "layout/postit",
                            "layout/pajem_widget",
                            "layout/audit_log",
                            "layout/trash",
                            "layout/share",
                            "layout/dashboard",
                            "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% if user_signed_in? %>
      <%= render "shared/topbar" %>

      <div class="app-shell">
        <%= render "shared/sidebar" %>

        <main class="content-area">
          <%= render "shared/flash" %>

          <% unless content_for?(:hide_content_header) %>
            <div class="content-header">
              <h1 class="content-header__title">
                <%= content_for?(:page_title) ? yield(:page_title) : "Pajem" %>
              </h1>
              <div class="content-header__actions">
                <%= link_to "+ Nova Lista", new_list_path, class: "btn btn--primary" %>
              </div>
            </div>
          <% end %>

          <%= yield %>
        </main>
      </div>

      <div class="pajem-widget" data-controller="pajem-chat">
        <div class="pajem-chat" data-pajem-chat-target="panel" hidden>
          <div class="pajem-chat__header">
            <img src="/Pajem.jpg" alt="Pajem" class="pajem-chat__header-avatar">
            <span class="pajem-chat__header-name">Pajem</span>
            <button class="pajem-chat__close"
                    data-action="click->pajem-chat#close"
                    aria-label="Fechar chat">&#x2715;</button>
          </div>
          <div class="pajem-chat__messages"
               id="pajem-messages"
               data-pajem-chat-target="messages">
            <p class="pajem-chat__welcome">Olá! Estou aqui para cuidar das suas listas.</p>
          </div>
          <div class="pajem-chat__footer">
            <form id="pajem-form"
                  action="<%= pajem_messages_path %>"
                  method="post"
                  data-action="turbo:submit-start->pajem-chat#onSubmitStart turbo:submit-end->pajem-chat#onSubmitEnd">
              <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
              <input type="text"
                     name="message"
                     class="pajem-chat__input"
                     data-pajem-chat-target="input"
                     placeholder="Digite um comando..."
                     aria-label="Mensagem para o Pajem"
                     autocomplete="off">
              <button type="submit" class="pajem-chat__send">Enviar</button>
            </form>
          </div>
        </div>

        <button class="pajem-widget__btn"
                data-action="click->pajem-chat#toggle"
                data-pajem-chat-target="btn"
                aria-label="Abrir assistente Pajem">
          <img src="/Pajem.jpg" alt="Pajem" class="pajem-widget__avatar">
        </button>
      </div>
    <% else %>
      <%= yield %>
    <% end %>
  </body>
</html>
