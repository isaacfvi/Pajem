<div class="inner-card">
  <h1 class="inner-card__title"><%= title %></h1>

  <% if context.errors.any? %>
    <div class="form-error-list">
      <% context.errors.full_messages.each do |msg| %>
        <p class="form-error-list__item">&#x26A0; <%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <%= form_with model: context, url: url do |f| %>
    <div class="form-group">
      <%= f.label :name, "Nome", class: "form-label" %>
      <%= f.text_field :name,
            class: "form-input #{'form-input--error' if context.errors[:name].any?}",
            placeholder: "Ex: Trabalho, Casa, Estudos…",
            autofocus: true %>
    </div>

    <div class="form-actions">
      <%= f.submit submit_label, class: "btn btn--primary" %>
      <%= link_to "Cancelar", lists_path, class: "btn btn--ghost" %>
    </div>
  <% end %>
</div>
