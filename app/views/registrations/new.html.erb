<% content_for :title, "Criar conta — Pajem" %>

<div class="auth-page">
  <div class="auth-card">
    <h1 class="auth-card__title">Criar conta</h1>

    <%= render "shared/flash" %>

    <% if @user.errors.any? %>
      <div class="form-error-list">
        <% @user.errors.full_messages.each do |msg| %>
          <p class="form-error-list__item">&#x26A0; <%= msg %></p>
        <% end %>
      </div>
    <% end %>

    <%= form_with model: @user, url: signup_path do |f| %>
      <div class="form-group">
        <%= f.label :name, "Nome", class: "form-label" %>
        <%= f.text_field :name,
              class: "form-input #{'form-input--error' if @user.errors[:name].any?}",
              placeholder: "Seu nome",
              autocomplete: "name",
              autofocus: true %>
      </div>

      <div class="form-group">
        <%= f.label :email, "E-mail", class: "form-label" %>
        <%= f.email_field :email,
              class: "form-input #{'form-input--error' if @user.errors[:email].any?}",
              placeholder: "voce@exemplo.com",
              autocomplete: "email" %>
      </div>

      <div class="form-group">
        <%= f.label :password, "Senha", class: "form-label" %>
        <%= f.password_field :password,
              class: "form-input #{'form-input--error' if @user.errors[:password].any?}",
              placeholder: "Mínimo 8 caracteres",
              autocomplete: "new-password" %>
      </div>

      <div class="form-group">
        <%= f.label :password_confirmation, "Confirmar senha", class: "form-label" %>
        <%= f.password_field :password_confirmation,
              class: "form-input #{'form-input--error' if @user.errors[:password_confirmation].any?}",
              placeholder: "••••••••",
              autocomplete: "new-password" %>
      </div>

      <div class="form-actions">
        <%= f.submit "Criar conta", class: "btn btn--primary" %>
      </div>
    <% end %>

    <div class="auth-card__footer">
      <p class="form-link">Já tem uma conta? <%= link_to "Faça login", login_path %></p>
    </div>
  </div>
</div>
