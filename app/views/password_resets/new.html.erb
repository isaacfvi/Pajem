<% content_for :title, "Recuperar senha — Pajem" %>

<h1>Recuperar senha</h1>

<p>Informe seu e-mail e enviaremos as instruções para redefinir sua senha.</p>

<%= form_with url: "/password/forgot" do |f| %>
  <div>
    <%= f.label :email, "E-mail" %>
    <%= f.email_field :email, name: "email", autocomplete: "email" %>
  </div>

  <%= f.submit "Enviar instruções" %>
<% end %>

<p><%= link_to "Voltar ao login", login_path %></p>
