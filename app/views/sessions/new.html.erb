<% content_for :title, "Entrar — Pajem" %>

<h1>Entrar</h1>

<%= form_with url: "/login" do |f| %>
  <div>
    <%= f.label :email, "E-mail" %>
    <%= f.email_field :email, name: "email", autocomplete: "email" %>
  </div>

  <div>
    <%= f.label :password, "Senha" %>
    <%= f.password_field :password, name: "password", autocomplete: "current-password" %>
  </div>

  <%= f.submit "Entrar" %>
<% end %>

<p><%= link_to "Esqueci minha senha", forgot_password_path %></p>
<p>Não tem uma conta? <%= link_to "Cadastre-se", signup_path %></p>
